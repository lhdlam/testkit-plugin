name: Desktop GUI Tests (pytest-qt, headless)
on:
  pull_request:
  push:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    env:
      QT_QPA_PLATFORM: offscreen
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: '3.11' }
      - run: sudo apt-get update && sudo apt-get install -y xvfb libxkbcommon-x11-0 libegl1
      - run: pip install -r requirements-dev.txt
      - run: xvfb-run --auto-servernum pytest -q
